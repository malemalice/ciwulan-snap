# ─── Database ────────────────────────────────────────────────────────────────
# Supported: postgres | mysql | mariadb
DB_TYPE=postgres
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=mydb
DB_USER=backup_user
DB_PASSWORD=

# ─── S3-Compatible Storage ───────────────────────────────────────────────────
# Works with: AWS S3, Backblaze B2, Cloudflare R2, Wasabi, DigitalOcean Spaces, MinIO
# Leave S3_ENDPOINT_URL empty for native AWS S3.
# Examples:
#   Backblaze B2:          https://s3.us-west-004.backblazeb2.com
#   Cloudflare R2:         https://<account_id>.r2.cloudflarestorage.com
#   DigitalOcean Spaces:   https://<region>.digitaloceanspaces.com
#   MinIO (self-hosted):   http://localhost:9000
S3_ENDPOINT_URL=
S3_BUCKET=my-db-backups
# Namespace backups per server so one bucket can hold multiple VPS backups
S3_PREFIX=vps-hostname/
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── Retention ───────────────────────────────────────────────────────────────
RETENTION_DAYS=30

# ─── Compression ─────────────────────────────────────────────────────────────
# gzip (default, widely supported) | zstd (faster, better ratio)
COMPRESSION_ALGO=gzip

# ─── Alerting ────────────────────────────────────────────────────────────────
# At least one of webhook or SMTP should be configured for failure alerts.

# Slack / Discord webhook (POST with {"text": "..."})
ALERT_WEBHOOK_URL=

# SMTP fallback
ALERT_SMTP_HOST=
ALERT_SMTP_PORT=587
ALERT_SMTP_USER=
ALERT_SMTP_PASSWORD=
ALERT_SMTP_FROM=
ALERT_SMTP_TO=
